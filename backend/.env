FLASK_ENV=development
SECRET_KEY=dev-secret-key-servicehub-local
JWT_SECRET_KEY=dev-jwt-secret-servicehub-local
# SQLite — no external database needed
# DATABASE_URL=sqlite:///servicehub.db  (this is the default, no need to set it)
# Uncomment below only if you have PostgreSQL:
# DATABASE_URL=postgresql://user:pass@localhost:5432/servicehub
# Redis is optional — leave blank to run without it
REDIS_URL=
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
